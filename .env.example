# ================================================================
# NexusPro Platform — Environment Variables
# ================================================================
# NEVER commit this file with real values.
# Use a secrets manager (AWS Secrets Manager / HashiCorp Vault) in production.
# Copy this to .env and fill in your values.
# ================================================================

# ── DATABASE ─────────────────────────────────────────────────
# Strong password: min 32 chars, mix of letters/numbers/symbols
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_32_CHARS_MIN

# ── REDIS ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT ─────────────────────────────────────────────────────
# MUST be at least 64 characters for HS512.
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64_AT_LEAST_64_CHARS

# ── ANTHROPIC (Claude AI) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── EMAIL (SendGrid / Postmark / SES) ───────────────────────
MAIL_HOST=smtp.sendgrid.net
MAIL_USERNAME=apikey
MAIL_PASSWORD=SG.CHANGE_ME

# ── STORAGE (S3 for CV/file uploads) ────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=nexuspro-uploads
AWS_REGION=eu-west-2

# ── MONITORING ───────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── CORS ALLOWED ORIGINS ─────────────────────────────────────
ALLOWED_ORIGINS=https://nexuspro.co.uk,https://app.nexuspro.co.uk
